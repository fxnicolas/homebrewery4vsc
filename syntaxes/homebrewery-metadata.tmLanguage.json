{
    "name": "HomebreweryMetadata",
    "scopeName": "homebrewery.metadata",
    "injectionSelector": "L:text.html.markdown",
    "patterns": [
        {
            "begin": "(```|~~~)\\s*metadata\\s*$",
            "end": "(```|~~~)",
            "name": "markup.fenced_code.block.metadata",
            "patterns": [ { "include": "source.yaml" } ]
        }
    ]
}