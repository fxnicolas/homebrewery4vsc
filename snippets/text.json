{
	"Insert Colunm Break": {
		"prefix": "Homebrewery Colunm Break",
		"body": "\\column",
		"description": "Column Break"
	},
	"Insert Page Break": {
		"prefix": "Homebrewery Page Break",
		"body": "\\page",
		"description": "Page Break"
	},
	"Insert Vertical Spacing": {
		"prefix": "Homebrewery Vertical Spacing",
		"body": "::::",
		"description": "Vertical Spacing"
	},
	"Insert Horizontal Spacing": {
		"prefix": "Homebrewery Horizontal Spacing",
		"body": "{{width:100px}}",
		"description": "Horizontal Spacing"
	},
	"Insert Wide Text Block": {
		"prefix": "Homebrewery Wide Text Block",
		"body": [
			"{{wide",
			"Everything in here will be extra wide. Tables, text, everything!",
			"Beware though, CSS columns can behave a bit weird sometimes. You may have to manually place column breaks with `\\column` to make the",
			"surrounding text flow with this wide block the way you want.",
			"}}"
		],
		"description": "Wide Text Block"
	},
	"Insert QR Code": {
		"prefix": "Homebrewery QR",
		"body": "![](https://api.qrserver.com/v1/create-qr-code/?data=https://marketplace.visualstudio.com/items?itemName=SpjakSoftware.homebrewery4vsc&amp;size=100x100) {width:100px;mix-blend-mode:multiply}",
		"description": "QR Code"
	},
	"Insert Page Link": {
		"prefix": "Homebrewery Page Link",
		"body": "[Click here](#p3) to go to page 3",
		"description": "Local Page Link"
	},
	"Insert Page Number": {
		"prefix": "Homebrewery Page Number",
		"body": [
			"{{pageNumber 1}}"
		],
		"description": "Custom Page Number and Footnote"
	},
	"Insert Page Number (Auto Increment)": {
		"prefix": "Homebrewery Page Number (Auto Increment)",
		"body": [
			"{{pageNumber,auto}}"
		],
		"description": "Auto Incrementing Page Number"
	},
	"Insert Page Number (Reset Increment)": {
		"prefix": "Homebrewery Page Number (Reset Increment)",
		"body": [
			"{{resetCounting}}",
			"{{pageNumber,auto}}"
		],
		"description": "Reset Page Number Increment"
	},
	"Insert Page Number (Skip Increment)": {
		"prefix": "Homebrewery Page Number (Skip Increment)",
		"body": [
			"{{skipCounting}}",
			"{{pageNumber,auto}}"
		],
		"description": "Skip Page Number Increment for this page"
	},
	"Insert Table Of Contents": {
		"prefix": "Homebrewery TOC",
		"body": [
			"{{toc,wide",
			"# Table Of Contents",
			"",
			"- ### [{{ Homebrewery for VS Code}}{{ 1}}](#p1)",
			"- [{{ Subheading }}{{ 1}}](#p1)",
			"- [{{ Another subheading }}{{ 1}}](#p1)",
			"- #### [{{ Features }}{{ 2}}](#p2)",
			"- [{{ Preview}}{{ 2}}](#p2)",
			"- [{{ Generate }}{{ 2}}](#p2)",
			"}}"
		],
		"description": "Table of Contents (Manual edit)"
	},
	"Insert Comment": {
		"prefix": "Homebrewery Comment",
		"body": "<!-- This is a comment. It won't show up in the generated document. -->",
		"description": "Comment"
	},
	"Insert Footer from H1": {
		"prefix": "Homebrewery Footer from H1",
		"body": "{{footnote H1}}",
		"description": "Footer from H1"
	},
	"Insert Footer from H2": {
		"prefix": "Homebrewery Footer from H2",
		"body": "{{footnote H2}}",
		"description": "Footer from H2"
	},
	"Insert Footer from H3": {
		"prefix": "Homebrewery Footer from H3",
		"body": "{{footnote H3}}",
		"description": "Footer from H3"
	},
	"Insert Footer from H4": {
		"prefix": "Homebrewery Footer from H4",
		"body": "{{footnote H4}}",
		"description": "Footer from H4"
	},
	"Insert Footer from H5": {
		"prefix": "Homebrewery Footer from H5",
		"body": "{{footnote H5}}",
		"description": "Footer from H5"
	},
	"Insert Footer from H6": {
		"prefix": "Homebrewery Footer from H6",
		"body": "{{footnote H6}}",
		"description": "Footer from H6"
	},
	"Insert Footer Text": {
		"prefix": "Homebrewery Footer Text",
		"body": "{{footnote Footer Text}}",
		"description": "Footer with free text."
	}
}